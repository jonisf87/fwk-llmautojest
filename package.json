{
  "name": "fmw-llmmautojest",
  "version": "1.0.0",
  "description": "LLM-as-a-Judge integration testing framework with Jest. Provider-agnostic, runs with any OpenAI-compatible API. Workshop & interview reference.",
  "main": "index.js",
  "scripts": {
    "test": "NODE_ENV=test dotenv -e environments/local.env -- jest --silent=false",
    "test:ci": "NODE_ENV=test dotenv -e environments/local.env -- jest --silent=false --testPathPattern=\"structural|semantic\"",
    "test:eval": "NODE_ENV=test dotenv -e environments/local.env -- jest --silent=false --testPathPattern=\"eval\"",
    "test:debug": "NODE_ENV=test dotenv -e environments/local.env -- node --inspect=0.0.0.0:9238 node_modules/.bin/jest --runInBand --silent=false",
    "lint": "eslint --max-warnings 0 \"src/**/*.ts\"",
    "lint:fix": "eslint --fix --max-warnings 0 \"src/**/*.ts\""
  },
  "keywords": [
    "llm",
    "llm-as-judge",
    "integration-testing",
    "jest",
    "ai-evaluation",
    "openai",
    "anthropic",
    "gemini"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@swc/core": "^1.11.29",
    "@swc/jest": "^0.2.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.17.0",
    "jest": "^30.0.0",
    "jest-matcher-utils": "^30.0.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "openai": "^4.82.0",
    "uuid": "^11.0.0",
    "@types/uuid": "^10.0.0"
  }
}
