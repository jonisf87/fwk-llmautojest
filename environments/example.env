# fmw-llmmautojest — example configuration
#
# Copy this file to environments/local.env (gitignored) and fill in your keys.
# Run tests with: npm test
#
# At minimum you need ONE agent provider key and ONE judge key.
# Cheapest option: GEMINI_API_KEY for both agent and judge (Gemini 1.5 Flash is free tier).

# ============================================================
# Agent provider API keys (provide at least one)
# ============================================================

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Custom OpenAI-compatible endpoint (ollama, LM Studio, Azure, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1

# ============================================================
# AI Judge configuration
# ============================================================

# Judge provider: gemini (default) | anthropic
JUDGE_PROVIDER=gemini

# Judge model (defaults: gemini-1.5-flash / claude-3-5-haiku-20241022)
# JUDGE_MODEL=gemini-1.5-flash

# ============================================================
# Models to test
#
# JSON map of provider group → array of model configs.
# Each entry: { "id": "<unique>", "provider": "<GROUP>", "model": "<api-model-id>" }
#
# Supported provider groups: OPENAI, ANTHROPIC, GEMINI
# ============================================================

# Minimal — single model
AI_TEST_MODELS={"OPENAI":[{"id":"1","provider":"OPENAI","model":"gpt-4o-mini"}]}

# Multi-provider example (uncomment and adjust)
# AI_TEST_MODELS={"OPENAI":[{"id":"1","provider":"OPENAI","model":"gpt-4o-mini"},{"id":"2","provider":"OPENAI","model":"gpt-4o"}],"ANTHROPIC":[{"id":"3","provider":"ANTHROPIC","model":"claude-3-5-haiku-20241022"}],"GEMINI":[{"id":"4","provider":"GEMINI","model":"gemini-1.5-flash"}]}

# ============================================================
# Eval / quality thresholds
# ============================================================

# Minimum AI Judge score (0–10) to pass a semantic/eval test
AI_SEMANTIC_PASS_THRESHOLD=7

# Relaxed threshold for tests sensitive to data variation
AI_PASS_THRESHOLD_RELAXED=6

# Grounding: max relative error |extracted - truth| / truth (5%)
GROUNDING_PCT_ERROR_THRESHOLD=0.05

# ============================================================
# Eval run options
# ============================================================

# Scenario scope: full (all turns) | canary (first turn only, fast smoke)
EVAL_SCENARIO_SCOPE=full

# Label for CSV rows — useful for grouping runs in dashboards
# EVAL_RUN_LABEL=my-run-2024-01-15

# Number of paraphrase repetitions per variant in robustness tests
ROBUSTNESS_VARIANT_RUNS=1

# Treat unexpected tool calls as failures (default: false = informational only)
EVAL_STRICT_TOOLS=false

# Tier B provider groups: comma-separated group names or 'all'
# Controls which providers run Tier B golden-dataset scenarios
TIER_B_PROVIDER_GROUPS=OPENAI

# ============================================================
# CSV export
# ============================================================

# Set to 'true' to write eval results to reports/eval/*.csv
AI_CSV_EXPORT_ENABLED=false

# Output directory (relative to project root)
# AI_CSV_EXPORT_DIR=reports/eval

# ============================================================
# Debug
# ============================================================

# Set to 'true' to print verbose agent request/response logs
AI_DEBUG=false
